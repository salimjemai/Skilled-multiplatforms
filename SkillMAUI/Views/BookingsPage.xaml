<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Skilled.Views.BookingsPage"
             Title="Bookings">

    <Grid RowDefinitions="Auto,*">

        <!-- Filter Tabs -->
        <HorizontalStackLayout Grid.Row="0" Spacing="0" HorizontalOptions="FillAndExpand">
            <Button Text="Upcoming"
                    Command="{Binding SelectUpcomingCommand}"
                    BackgroundColor="{Binding IsUpcomingSelected, Converter={StaticResource BoolToColorConverter}}"
                    TextColor="White"
                    HorizontalOptions="FillAndExpand"
                    CornerRadius="0" />
            <Button Text="Past"
                    Command="{Binding SelectPastCommand}"
                    BackgroundColor="{Binding IsPastSelected, Converter={StaticResource BoolToColorConverter}}"
                    TextColor="White"
                    HorizontalOptions="FillAndExpand"
                    CornerRadius="0" />
        </HorizontalStackLayout>

        <!-- Bookings List -->
        <CollectionView Grid.Row="1"
                       ItemsSource="{Binding Bookings}"
                       SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label Text="No bookings found" FontSize="18" TextColor="Gray" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="15,8" Padding="15" CornerRadius="10" HasShadow="True">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding ProviderName}"
                                   FontAttributes="Bold" FontSize="16" />
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Status}"
                                   FontSize="12" TextColor="Gray"
                                   HorizontalOptions="End" />

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding ServiceName}"
                                   FontSize="13" TextColor="Gray" />
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding TotalAmount, StringFormat='${0:F2}'}"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="DarkGreen" HorizontalOptions="End" />

                            <Label Grid.Row="2" Grid.ColumnSpan="2"
                                   Text="{Binding Date, StringFormat='{0:MMM dd, yyyy h:mm tt}'}"
                                   FontSize="12" TextColor="Gray"
                                   Margin="0,5,0,0" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="1"
                          IsRunning="{Binding IsLoading}"
                          IsVisible="{Binding IsLoading}"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />

    </Grid>

</ContentPage>
